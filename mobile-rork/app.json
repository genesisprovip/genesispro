{
  "expo": {
    "name": "GenesisPro",
    "slug": "genesispro",
    "version": "1.8.4",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "genesispro",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.genesispro.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      },
      "package": "com.genesispro.app",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "updates": {
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/7bae4097-6940-4dd2-84cb-40531ee8556f"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://genesispro.vip/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "GenesisPro necesita acceso a la camara para transmitir en vivo"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "GenesisPro necesita acceso al microfono para transmitir en vivo"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 35,
            "targetSdkVersion": 34
          }
        }
      ],
      "expo-video",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/sounds/fight_alert.wav",
            "./assets/sounds/notification.wav"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": "https://genesispro.vip/"
      },
      "eas": {
        "projectId": "7bae4097-6940-4dd2-84cb-40531ee8556f"
      }
    },
    "owner": "genesispro"
  }
}
