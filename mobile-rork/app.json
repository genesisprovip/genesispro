{
  "expo": {
    "name": "GenesisPro",
    "slug": "genesispro",
    "version": "1.5.8",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "genesispro",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.genesispro.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      },
      "package": "com.genesispro.app",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/f82dbac6-7a51-46a4-9e25-af9ab66535a1"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://genesispro.vip/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-updates",
      [
        "expo-camera",
        {
          "cameraPermission": "GenesisPro necesita acceso a la camara para transmitir en vivo"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "GenesisPro necesita acceso al microfono para transmitir en vivo"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 35,
            "targetSdkVersion": 34
          }
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": "https://genesispro.vip/"
      },
      "eas": {
        "projectId": "f82dbac6-7a51-46a4-9e25-af9ab66535a1"
      }
    },
    "owner": "auralink"
  }
}
