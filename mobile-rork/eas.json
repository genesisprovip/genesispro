{
  "cli": {
    "version": ">= 18.0.0"
  },
  "build": {
    "base": {
      "node": "22.16.0",
      "env": {
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
        "YARN_IGNORE_ENGINES": "true"
      }
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "credentialsSource": "local"
      },
      "channel": "preview"
    },
    "production": {
      "extends": "base",
      "android": {
        "buildType": "apk"
      },
      "autoIncrement": true,
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-services.json",
        "track": "internal"
      }
    }
  }
}
